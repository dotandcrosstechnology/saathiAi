# ─────────────────────────────────────────────────────────────
# SaathiAI — Environment Variables
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────────────────

# Firebase
EXPO_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
EXPO_PUBLIC_FIREBASE_PROJECT_ID=your_firebase_project_id_here
EXPO_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id_here

# Google Maps
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Google Gemini (primary LLM — tried first)
EXPO_PUBLIC_GEMINI_API_KEY=your_gemini_api_key_here

# Groq (fallback LLM on Gemini 429/timeout — free tier at console.groq.com)
EXPO_PUBLIC_GROQ_API_KEY=EXPO_PUBLIC_GROQ_API_KEY=your_groq_api_key_here
